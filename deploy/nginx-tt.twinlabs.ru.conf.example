# Пример для поддомена tt.twinlabs.ru (приложение с корня, без /pm-board).
# 1) Собрать: TEAM_TRACKER_ROOT_DOMAIN=1 npm run build
# 2) systemd: Environment=TEAM_TRACKER_ROOT_DOMAIN=1 NODE_ENV=production PORT=3005
# 3) certbot --nginx -d tt.twinlabs.ru

server {
    listen 80;
    server_name tt.twinlabs.ru;
    location / {
        proxy_pass http://127.0.0.1:3005;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
