# Скопируйте на сервер как /etc/team-tracker.env (chmod 600) и подставьте значения.
# Не коммитьте этот файл с реальными секретами.

TEAM_TRACKER_AUTH_SECRET=замените_на_случайную_строку_32plus
# Sophia OS / API: тот же секрет в EXPO_PUBLIC_TEAMTRACKER_INTEGRATION_SECRET (EAS / sophia.env), минимум 16 символов.
# TT_INTEGRATION_SECRET=...
# Публичная регистрация на /login (роль member). Отключить: =0
TEAM_TRACKER_SELF_REGISTER=1
# Опционально: 1 = всегда Secure-cookie, 0 = никогда (например только http://IP:PORT). По умолчанию — по X-Forwarded-Proto.
# TEAM_TRACKER_COOKIE_SECURE=1
# Те же логины/пароли, что в Twinworks — JSON-массив одной строкой:
TEAM_TRACKER_USERS_JSON=[{"login":"ivan","password":"...","name":"Иван","title":"Дизайнер"}]
