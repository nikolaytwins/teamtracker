# Скопируйте на сервер как /etc/team-tracker.env (chmod 600) и подставьте значения.
# Рабочая копия (не в git): deploy/team-tracker.env

# --- Supabase (v2) ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ВСТАВЬТЕ_SERVICE_ROLE_KEY
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# Agency v1 (/agency) всегда на SQLite (см. AGENCY_SQLITE_PATH ниже).
# v2 (/v2/agency) читает/пишет в Supabase — после миграций выполните: npm run import-agency-to-supabase
# AGENCY_DATABASE=supabase  # устарело для v1; v1 игнорирует этот флаг

TEAM_TRACKER_AUTH_SECRET=замените_на_случайную_строку_32plus
# Sophia OS / API: тот же секрет в EXPO_PUBLIC_TEAMTRACKER_INTEGRATION_SECRET (EAS / sophia.env), минимум 16 символов.
# TT_INTEGRATION_SECRET=...
TEAM_TRACKER_SELF_REGISTER=1
# TEAM_TRACKER_COOKIE_SECURE=1
# TEAM_TRACKER_USERS_JSON=[{"login":"ivan","password":"...","name":"Иван","title":"Дизайнер"}]
# AGENCY_SQLITE_PATH=/opt/team-tracker/data/agency.db
# PM_BOARD_SQLITE_PATH=/opt/team-tracker/data/pm-board.db
