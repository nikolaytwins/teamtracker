# Скопируй в `.env.local` (или `.env`) и подставь значения. Файлы `.env*` не коммитятся.

# Сессии Teamtracker (логин в веб-интерфейс). Сгенерируй: openssl rand -hex 32
# TT_AUTH_SECRET=

# Интеграция Sophia OS → GET …/api/integrations/sophia/agency-profit
# Минимум 16 символов; тот же секрет в EXPO_PUBLIC_TEAMTRACKER_INTEGRATION_SECRET в Sophia.
TT_INTEGRATION_SECRET=replace-with-long-random-secret-min-16-chars

# Локально без /pm-board в URL (опционально): TEAM_TRACKER_ROOT_DOMAIN=1

# Прод tt.twinlabs.ru: публичный URL (если редиректы ведут на localhost:PORT — обязательно на сервере).
# TEAM_TRACKER_PUBLIC_ORIGIN=https://tt.twinlabs.ru

# Тот же секрет в Sophia: EXPO_PUBLIC_TEAMTRACKER_INTEGRATION_SECRET (на сервере в unit / env деплоя).

# Опционально: если приложение за префиксом (reverse proxy)
# NEXT_PUBLIC_BASE_PATH=
