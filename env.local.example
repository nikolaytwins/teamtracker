# Скопируйте в .env.local и подставьте свои значения:
#   cp env.local.example .env.local
# Файл .env.local в git не попадает (см. .gitignore).

# --- Supabase (агентство: при заполненных URL + service key включается автоматически) ---
# Dashboard → Settings → API:
#   https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api-keys
# Документация: https://supabase.com/docs/guides/api/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_OR_LEGACY_SERVICE_ROLE_JWT

# Публичный anon key (Dashboard → Settings → API) — для опционального входа через Supabase Auth:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_... или legacy anon JWT
# Пока ключ задан и у пользователя есть email (логин с @ или колонка auth_email), пароль проверяется в Supabase.
# Отключить этот режим: TEAM_TRACKER_SUPABASE_AUTH=0

# Явно оставить SQLite, даже если ключи заданы (локальная отладка):
# AGENCY_DATABASE=sqlite

# Явно потребовать Supabase (без ключей репозиторий откатится на SQLite):
# AGENCY_DATABASE=supabase

# --- Agency SQLite (резерв / импорт / история вне ядра миграции) ---
# AGENCY_SQLITE_PATH=/absolute/path/to/agency.db

# --- Team Tracker (сессии и пользователи) ---
# TEAM_TRACKER_AUTH_SECRET=random-long-string-for-production
# TEAM_TRACKER_USERS_JSON=[{"login":"...","password":"...","name":"...","auth_email":"u@corp.com",...}]
# Саморегистрация на /login: в production включить TEAM_TRACKER_SELF_REGISTER=1; в dev по умолчанию включена; отключить: =0
# TEAM_TRACKER_SELF_REGISTER=1

# --- Опционально ---
# PM_BOARD_SQLITE_PATH=
# NEXT_PUBLIC_BASE_PATH=
# TWINWORKS_AGENCY_URL=http://127.0.0.1:3001
